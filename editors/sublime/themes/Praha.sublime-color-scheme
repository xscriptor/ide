{
  "name": "Xscriptor Praha",
  "globals": {
    "background": "#1a1a1a",
    "foreground": "#ffffff",
    "caret": "#FF9AA2",
    "invisibles": "#6272A4",
    "line_highlight": "#252525",
    "selection": "rgba(255, 255, 255, 0.15)",
    "selection_foreground": "#1a1a1a",
    "selection_border": "rgba(255, 255, 255, 0.3)",
    "inactive_selection": "rgba(255, 255, 255, 0.08)",
    "gutter": "#1a1a1a",
    "gutter_foreground": "#6272A4",
    "gutter_foreground_highlight": "#FF9AA2",
    "guide": "rgba(255, 255, 255, 0.1)",
    "active_guide": "#FF9AA2",
    "stack_guide": "rgba(255, 255, 255, 0.15)",
    "find_highlight": "rgba(255, 228, 163, 0.4)",
    "find_highlight_foreground": "#1a1a1a",
    "highlight": "rgba(255, 228, 163, 0.3)",
