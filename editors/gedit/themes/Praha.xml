<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE theme SYSTEM "gedit-color-scheme.dtd">
<theme>
  <name>Xscriptor Praha</name>
  <author>Xscriptor</author>
  <description>Xscriptor Praha theme for Gedit</description>
  <color name="background" value="#1a1a1a"/>
  <color name="foreground" value="#ffffff"/>
  <color name="cursor" value="#FF9AA2"/>
  <color name="selection" value="rgba(255, 255, 255, 0.15)"/>
  <color name="current_line" value="#252525"/>
  <color name="line_numbers" value="#6272A4"/>
  <color name="bracket_match" value="#FF9AA2"/>
  <color name="search_match" value="#FFE4A3"/>
  <!-- Styles -->
  <style name="text" foreground="#ffffff" background="#1a1a1a"/>
  <style name="cursor" foreground="#FF9AA2"/>
  <style name="current-line" background="#252525"/>
  <style name="line-numbers" foreground="#6272A4"/>
  <style name="selection" background="rgba(255, 255, 255, 0.15)"/>
  <style name="search-match" foreground="#1a1a1a" background="#FFE4A3"/>
  <!-- Syntax -->
  <style name="comment" foreground="#6272A4" italic="true"/>
  <style name="string" foreground="#B8E6A0"/>
  <style name="constant" foreground="#FFE4A3"/>
  <style name="constant.numeric" foreground="#FFE4A3"/>
  <style name="variable" foreground="#ffffff"/>
  <style name="keyword" foreground="#FF9AA2"/>
  <style name="type" foreground="#8BE9FD"/>
  <style name="function" foreground="#BD93F9"/>
  <style name="preprocessor" foreground="#FF6E6E"/>
  <style name="specials" foreground="#FF5555"/>
  <style name="def:linenumber" foreground="#6272A4"/>
</theme>