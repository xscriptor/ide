      "constant": "#8a6408",
      "constant.numeric": "#8a6408",
      "constant.character.escape": "#990026",
      "constant.builtin": "#8a6408",
      "string": "#007a28",
      "string.regex": "#007a28",
      "string.special": "#990026",
      "keyword": "#4d2699",
