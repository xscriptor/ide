{
  "name": "Xscriptor Madrid",
  "appearance": "light",
  "style": {
    "background": "#fafafa",
    "foreground": "#1a1a1a",
    "border": "rgba(77, 77, 77, 1.0)",
    "scrollbar.thumb.border": "rgba(77, 77, 77, 1.0)",
    "scrollbar.thumb.background": null,
    "scrollbar.track.background": null,
    "editor.background": "#fafafa",
    "editor.foreground": "#1a1a1a",
    "editor.cursor": "#4d2699",
    "editor.accents.color": "#4d2699",
