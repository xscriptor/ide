{
  "name": "Xscriptor London",
  "type": "theme",
  "colors": {
    "editor.background": "#ffffff",
    "editor.foreground": "#333333",
    "editorCursor.foreground": "#777777",
    "editor.selectionBackground": "#e0e0e0",
    "editor.lineHighlightBackground": "#f5f5f5",
    "editorLineNumber.foreground": "#333333",
    "editorLineNumber.activeForeground": "#777777",
    "editorGutter.background": "#ffffff",
    "editorBracketMatch.background": "#f5f5f5",
    "editorBracketMatch.border": "#777777",
    "editor.findMatchHighlightBackground": "rgba(85, 85, 85, 0.3)",
    "editor.findMatchBackground": "#555555",
    "editorWidget.background": "#ffffff",
    "editorWidget.foreground": "#333333",
    "inputValidation.infoBackground": "rgba(136, 136, 136, 0.3)",
    "inputValidation.warningBackground": "rgba(85, 85, 85, 0.3)",
    "inputValidation.errorBackground": "rgba(51, 51, 51, 0.3)"
  },
  "tokenColors": [
    {"scope": "comment", "settings": {"foreground": "#333333", "fontStyle": "italic"}},
    {"scope": "string", "settings": {"foreground": "#444444"}},
    {"scope": "constant.numeric", "settings": {"foreground": "#555555"}},
    {"scope": "keyword", "settings": {"foreground": "#777777"}},
    {"scope": "storage.type", "settings": {"foreground": "#888888"}},
    {"scope": "entity.name.function", "settings": {"foreground": "#666666"}},
    {"scope": "entity.name.type", "settings": {"foreground": "#888888"}},
    {"scope": "variable", "settings": {"foreground": "#333333"}},
    {"scope": "variable.language", "settings": {"foreground": "#333333"}},
    {"scope": "constant", "settings": {"foreground": "#555555"}},
    {"scope": "support.function", "settings": {"foreground": "#666666"}},
    {"scope": "support.type", "settings": {"foreground": "#888888"}},
    {"scope": "entity.other.attribute-name", "settings": {"foreground": "#555555"}},
    {"scope": "entity.name.tag", "settings": {"foreground": "#333333"}},
    {"scope": "markup.heading", "settings": {"foreground": "#888888", "fontStyle": "bold"}},
    {"scope": "markup.list", "settings": {"foreground": "#333333"}}
  ]
}
