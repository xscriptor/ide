<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE theme SYSTEM "gedit-color-scheme.dtd">
<theme>
  <name>Xscriptor Berlin</name>
  <author>Xscriptor</author>
  <description>Xscriptor Berlin theme for Gedit</description>
  <color name="background" value="#000000"/>
  <color name="foreground" value="#cccccc"/>
  <color name="cursor" value="#aaaaaa"/>
  <color name="selection" value="rgba(204, 204, 204, 0.15)"/>
  <color name="current_line" value="#0a0a0a"/>
  <color name="line_numbers" value="#666666"/>
  <color name="bracket_match" value="#aaaaaa"/>
  <color name="search_match" value="#dddddd"/>
  <!-- Styles -->
  <style name="text" foreground="#cccccc" background="#000000"/>
  <style name="cursor" foreground="#aaaaaa"/>
  <style name="current-line" background="#0a0a0a"/>
  <style name="line-numbers" foreground="#666666"/>
  <style name="selection" background="rgba(204, 204, 204, 0.15)"/>
  <style name="search-match" foreground="#000000" background="#dddddd"/>
  <!-- Syntax -->
  <style name="comment" foreground="#666666" italic="true"/>
  <style name="string" foreground="#bbbbbb"/>
  <style name="constant" foreground="#dddddd"/>
  <style name="constant.numeric" foreground="#dddddd"/>
  <style name="variable" foreground="#cccccc"/>
  <style name="keyword" foreground="#aaaaaa"/>
  <style name="type" foreground="#cccccc"/>
  <style name="function" foreground="#888888"/>
  <style name="preprocessor" foreground="#bbbbbb"/>
  <style name="specials" foreground="#999999"/>
  <style name="def:linenumber" foreground="#666666"/>
</theme>