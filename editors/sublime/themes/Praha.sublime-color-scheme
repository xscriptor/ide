  "rules": [
    {
      "name": "Comment",
      "scope": "comment",
      "foreground": "#6272A4",
      "font_style": "italic"
    },
    {
      "name": "Comment Line",
      "scope": "comment.line",
      "foreground": "#6272A4"
    },
    {
      "name": "Comment Block",
      "scope": "comment.block",
      "foreground": "#6272A4"
    },
    {
      "name": "Keyword",
      "scope": "keyword",
      "foreground": "#FF9AA2"
    },
    {
      "name": "Keyword Control",
      "scope": "keyword.control",
      "foreground": "#FF9AA2"
    },
    {
      "name": "Keyword Operator",
      "scope": "keyword.operator",
      "foreground": "#FF9AA2"
    },
    {
      "name": "Storage",
      "scope": "storage",
      "foreground": "#FF9AA2"
    },
    {
      "name": "Storage Modifier",
      "scope": "storage.modifier",
      "foreground": "#FF9AA2"
    },
    {
      "name": "Storage Type",
      "scope": "storage.type",
      "foreground": "#8BE9FD"
    },
    {
      "name": "Constant",
      "scope": "constant",
      "foreground": "#FFE4A3"
    },
    {
      "name": "Constant Numeric",
      "scope": "constant.numeric",
      "foreground": "#FFE4A3"
    },
    {
      "name": "Constant Language",
      "scope": "constant.language",
      "foreground": "#FFE4A3"
    },
    {
      "name": "Constant Escape",
      "scope": "constant.character.escape",
      "foreground": "#FF6E6E"
    },
    {
      "name": "String",
      "scope": "string",
      "foreground": "#B8E6A0"
    },
    {
      "name": "String Quoted",
      "scope": "string.quoted",
      "foreground": "#B8E6A0"
    },
    {
      "name": "String Regexp",
      "scope": "string.regexp",
      "foreground": "#B8E6A0"
    },
    {
      "name": "String Other Link",
      "scope": "string.other.link",
      "foreground": "#FF6E6E"
    },
    {
      "name": "Function Name",
      "scope": "entity.name.function",
      "foreground": "#BD93F9"
    },
    {
      "name": "Function Call",
      "scope": "meta.function-call",
      "foreground": "#D6ACFF"
    },
    {
      "name": "Support Function",
      "scope": "support.function",
      "foreground": "#D6ACFF"
    },
    {
      "name": "Variable Function",
      "scope": "variable.function",
      "foreground": "#D6ACFF"
    },
    {
      "name": "Type Name",
      "scope": "entity.name.type",
      "foreground": "#8BE9FD"
    },
    {
      "name": "Class Name",
      "scope": "entity.name.class",
      "foreground": "#8BE9FD"
    },
    {
      "name": "Support Type",
      "scope": "support.type",
      "foreground": "#8BE9FD"
    },
    {
      "name": "Support Class",
      "scope": "support.class",
      "foreground": "#8BE9FD"
    },
    {
      "name": "Tag Name",
      "scope": "entity.name.tag",
      "foreground": "#FF5555"
    },
    {
      "name": "Attribute Name",
      "scope": "entity.other.attribute-name",
      "foreground": "#FFE4A3"
    },
    {
      "name": "Language Variable",
      "scope": "variable.language",
      "foreground": "#FF5555"
