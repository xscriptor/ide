<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE theme SYSTEM "gedit-color-scheme.dtd">
<theme>
  <name>Xscriptor London</name>
  <author>Xscriptor</author>
  <description>Xscriptor London theme for Gedit</description>
  <color name="background" value="#ffffff"/>
  <color name="foreground" value="#333333"/>
  <color name="cursor" value="#777777"/>
  <color name="selection" value="rgba(51, 51, 51, 0.15)"/>
  <color name="current_line" value="#f5f5f5"/>
  <color name="line_numbers" value="#333333"/>
  <color name="bracket_match" value="#777777"/>
  <color name="search_match" value="#555555"/>
  <!-- Styles -->
  <style name="text" foreground="#333333" background="#ffffff"/>
  <style name="cursor" foreground="#777777"/>
  <style name="current-line" background="#f5f5f5"/>
  <style name="line-numbers" foreground="#333333"/>
  <style name="selection" background="rgba(51, 51, 51, 0.15)"/>
  <style name="search-match" foreground="#ffffff" background="#555555"/>
  <!-- Syntax -->
  <style name="comment" foreground="#333333" italic="true"/>
  <style name="string" foreground="#444444"/>
  <style name="constant" foreground="#555555"/>
  <style name="constant.numeric" foreground="#555555"/>
  <style name="variable" foreground="#333333"/>
  <style name="keyword" foreground="#777777"/>
  <style name="type" foreground="#888888"/>
  <style name="function" foreground="#666666"/>
  <style name="preprocessor" foreground="#444444"/>
  <style name="specials" foreground="#333333"/>
  <style name="def:linenumber" foreground="#333333"/>
</theme>