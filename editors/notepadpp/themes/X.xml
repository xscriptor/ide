<?xml version="1.0" encoding="UTF-8"?>
<NotepadPlus>
  <Theme name="Xscriptor X">
    <GlobalStyle bgColor="050505" fgColor="F7F1FF" bold="no" italic="no"/>
    <WidgetStyle name="Global override" bgColor="050505" fgColor="F7F1FF"/>
    <WidgetStyle name="Selected text colour" bgColor="29282A" fgColor="F7F1FF"/>
    <WidgetStyle name="Caret colour" fgColor="948AE3"/>
    <WidgetStyle name="Line number margin" bgColor="050505" fgColor="7E7B82"/>
    <WidgetStyle name="Fold" bgColor="050505" fgColor="948AE3"/>
    <WidgetStyle name="Current line" bgColor="111112"/>
    <!-- Syntax -->
    <LexerType name="comment" fgColor="7E7B82" italic="yes"/>
    <LexerType name="commentline" fgColor="7E7B82" italic="yes"/>
    <LexerType name="string" fgColor="7BD88F"/>
    <LexerType name="number" fgColor="FCE566"/>
    <LexerType name="keyword" fgColor="948AE3"/>
    <LexerType name="type" fgColor="5AD4E6"/>
    <LexerType name="function" fgColor="FD9353"/>
    <LexerType name="preprocessor" fgColor="FC618D"/>
    <LexerType name="operator" fgColor="948AE3"/>
    <LexerType name="variable" fgColor="F7F1FF"/>
    <LexerType name="constant" fgColor="FCE566"/>
  </Theme>
</NotepadPlus>