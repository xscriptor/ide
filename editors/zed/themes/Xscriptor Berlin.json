{
  "name": "Xscriptor Berlin",
  "appearance": "dark",
  "style": {
    "background": "#000000",
    "foreground": "#cccccc",
    "border": "rgba(51, 51, 51, 1.0)",
    "scrollbar.thumb.border": "rgba(51, 51, 51, 1.0)",
    "scrollbar.thumb.background": null,
    "scrollbar.track.background": null,
    "editor.background": "#000000",
    "editor.foreground": "#cccccc",
    "editor.cursor": "#aaaaaa",
    "editor.accents.color": "#aaaaaa",
    "editor.accents.selected_index_color": "#aaaaaa",
    "editor.selection": "rgba(204, 204, 204, 0.15)",
    "editor.active_line": "#0a0a0a",
    "editor.line_number": "#666666",
    "editor.active_line_number": "#aaaaaa",
    "editor.gutter": "#000000",
    "editor.invisible_characters": "#666666",
    "editor.wrap_guides": "#666666",
    "editor.highlighted_line": "#0a0a0a",
    "editor.occurrence.border": "#aaaaaa",
    "editor.occurrence.background": null,
    "editor.diagnostics.background": null,
    "editor.diagnostics.border": null,
    "editor.diagnostics.warning.background": null,
    "editor.diagnostics.warning.border": "#dddddd",
    "editor.diagnostics.error.background": null,
    "editor.diagnostics.error.border": "#999999",
    "editor.diagnostics.info.background": null,
    "editor.diagnostics.info.border": "#cccccc",
    "editor.diagnostics.hint.background": null,
    "editor.diagnostics.hint.border": "#bbbbbb",
    "editor.active_line.background": "#0a0a0a",
    "editor.document_highlight.read_background": null,
    "editor.document_highlight.write_background": null,
    "editor.range_highlight.background": null,
    "editor.range_highlight.border": null,
    "syntax": {
      "comment": "#666666",
      "comment.doc": "#666666",
      "constant": "#dddddd",
      "constant.numeric": "#dddddd",
      "constant.character.escape": "#999999",
      "constant.builtin": "#dddddd",
      "string": "#bbbbbb",
      "string.regex": "#bbbbbb",
      "string.special": "#999999",
      "keyword": "#aaaaaa",
      "keyword.control": "#aaaaaa",
      "keyword.function": "#bbbbbb",
      "keyword.return": "#aaaaaa",
      "keyword.operator": "#aaaaaa",
      "function": "#888888",
      "function.call": "#888888",
      "function.builtin": "#888888",
      "function.macro": "#bbbbbb",
      "function.special": "#888888",
      "type": "#cccccc",
      "type.builtin": "#cccccc",
      "type.enum": "#cccccc",
      "constructor": "#cccccc",
      "variable": "#cccccc",
      "variable.builtin": "#999999",
      "variable.parameter": "#888888",
      "variable.member": "#cccccc",
      "variable.function": "#888888",
      "operator": "#aaaaaa",
      "punctuation": "#cccccc",
      "punctuation.delimiter": "#666666",
      "punctuation.bracket": "#cccccc",
      "markup.heading": "#cccccc",
      "markup.list": "#999999",
      "markup.bold": "#cccccc",
      "markup.italic": "#cccccc",
      "markup.link": "#cccccc",
      "markup.quote": "#333333",
      "markup.raw": "#bbbbbb",
      "markup.highlight": "#dddddd",
      "tag": "#999999",
      "tag.attribute": "#dddddd",
      "tag.delimiter": "#666666",
      "embedding": "#aaaaaa",
      "emphasis.strong": {
        "font_weight": "bold",
        "color": "#cccccc"
      },
      "emphasis.italic": {
        "font_style": "italic",
        "color": "#cccccc"
      },
      "emphasis.underline": {
        "font_style": "underline",
        "color": "#cccccc"
      }
    },
    "terminal": {
      "background": "#000000",
      "foreground": "#cccccc",
      "ansi": [
        "#000000",
        "#999999",
        "#bbbbbb",
        "#dddddd",
        "#888888",
        "#aaaaaa",
        "#cccccc",
        "#ffffff",
        "#333333",
        "#bbbbbb",
        "#dddddd",
        "#ffffff",
        "#aaaaaa",
        "#cccccc",
        "#eeeeee",
        "#ffffff"
      ]
    }
  }
}