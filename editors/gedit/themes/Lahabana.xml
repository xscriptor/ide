<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE theme SYSTEM "gedit-color-scheme.dtd">
<theme>
  <name>Xscriptor Lahabana</name>
  <author>Xscriptor</author>
  <description>Xscriptor Lahabana theme for Gedit</description>
  <color name="background" value="#19191a"/>
  <color name="foreground" value="#f7f1ff"/>
  <color name="cursor" value="#948ae3"/>
  <color name="selection" value="rgba(247, 241, 255, 0.15)"/>
  <color name="current_line" value="#242425"/>
  <color name="line_numbers" value="#67656a"/>
  <color name="bracket_match" value="#948ae3"/>
  <color name="search_match" value="#e5ff9d"/>
  <!-- Styles -->
  <style name="text" foreground="#f7f1ff" background="#19191a"/>
  <style name="cursor" foreground="#948ae3"/>
  <style name="current-line" background="#242425"/>
  <style name="line-numbers" foreground="#67656a"/>
  <style name="selection" background="rgba(247, 241, 255, 0.15)"/>
  <style name="search-match" foreground="#19191a" background="#e5ff9d"/>
  <!-- Syntax -->
  <style name="comment" foreground="#67656a" italic="true"/>
  <style name="string" foreground="#7bd88f"/>
  <style name="constant" foreground="#e5ff9d"/>
  <style name="constant.numeric" foreground="#e5ff9d"/>
  <style name="variable" foreground="#f7f1ff"/>
  <style name="keyword" foreground="#948ae3"/>
  <style name="type" foreground="#5ad4e6"/>
  <style name="function" foreground="#fd9353"/>
  <style name="preprocessor" foreground="#fc618d"/>
  <style name="specials" foreground="#fc618d"/>
  <style name="def:linenumber" foreground="#67656a"/>
</theme>