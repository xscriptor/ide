      "type.enum": "#007a9e",
      "constructor": "#007a9e",
      "variable": "#1a1a1a",
      "variable.builtin": "#990026",
      "variable.parameter": "#007a9e",
      "variable.member": "#1a1a1a",
      "variable.function": "#007a9e",
      "operator": "#4d2699",
      "punctuation": "#1a1a1a",
      "punctuation.delimiter": "#4d4d4d",
      "punctuation.bracket": "#1a1a1a",
      "markup.heading": "#007a9e",
      "markup.list": "#990026",
      "markup.bold": "#1a1a1a",
      "markup.italic": "#1a1a1a",
      "markup.link": "#007a9e",
      "markup.quote": "#4d4d4d",
