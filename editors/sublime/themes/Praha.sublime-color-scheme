    "accent": "#FF9AA2",
    "fold_marker": "#FF9AA2",
    "minimap_border": "rgba(255, 255, 255, 0.1)",
    "line_diff_added": "rgba(184, 230, 160, 0.25)",
    "line_diff_modified": "rgba(255, 228, 163, 0.25)",
    "line_diff_deleted": "rgba(255, 85, 85, 0.25)",
    "brackets_foreground": "#FFFFFF",
    "brackets_options": "underline",
    "bracket_contents_foreground": "#FFFFFF",
    "bracket_contents_options": "underline",
    "rulers": "#6272A4",
    "shadow": "rgba(26, 26, 26, 0.5)",
    "shadow_width": 6
