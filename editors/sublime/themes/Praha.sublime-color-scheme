      "foreground": "#FF6E6E",
      "font_style": "bold"
    },
    {
      "name": "Invalid Deprecated",
      "scope": "invalid.deprecated",
      "foreground": "#FF6E6E",
      "font_style": "bold"
    },
    {
      "name": "Punctuation",
      "scope": "punctuation",
      "foreground": "#FFFFFF"
    },
    {
      "name": "Punctuation Tag",
      "scope": "punctuation.definition.tag",
      "foreground": "#6272A4"
