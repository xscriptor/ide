<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE theme SYSTEM "gedit-color-scheme.dtd">
<theme>
  <name>Xscriptor Oslo</name>
  <author>Xscriptor</author>
  <description>Xscriptor Oslo theme for Gedit</description>
  <color name="background" value="#3f4451"/>
  <color name="foreground" value="#abb2bf"/>
  <color name="cursor" value="#c162de"/>
  <color name="selection" value="rgba(171, 178, 191, 0.15)"/>
  <color name="current_line" value="#444a56"/>
  <color name="line_numbers" value="#959ca9"/>
  <color name="bracket_match" value="#c162de"/>
  <color name="search_match" value="#d18f52"/>
  <!-- Styles -->
  <style name="text" foreground="#abb2bf" background="#3f4451"/>
  <style name="cursor" foreground="#c162de"/>
  <style name="current-line" background="#444a56"/>
  <style name="line-numbers" foreground="#959ca9"/>
  <style name="selection" background="rgba(171, 178, 191, 0.15)"/>
  <style name="search-match" foreground="#3f4451" background="#d18f52"/>
  <!-- Syntax -->
  <style name="comment" foreground="#959ca9" italic="true"/>
  <style name="string" foreground="#8cc265"/>
  <style name="constant" foreground="#d18f52"/>
  <style name="constant.numeric" foreground="#d18f52"/>
  <style name="variable" foreground="#abb2bf"/>
  <style name="keyword" foreground="#c162de"/>
  <style name="type" foreground="#42b3c2"/>
  <style name="function" foreground="#4aa5f0"/>
  <style name="preprocessor" foreground="#ff616e"/>
  <style name="specials" foreground="#e05561"/>
  <style name="def:linenumber" foreground="#959ca9"/>
</theme>